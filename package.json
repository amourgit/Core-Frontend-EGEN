{
  "name": "@egen/esm-core",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "packages/apps/*",
    "packages/framework/*",
    "packages/shell/*",
    "packages/tooling/*",
    "packages/shared/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter='@egen/esm-app-shell'",
    "start": "turbo run start --filter='@egen/esm-app-shell'",
    "build": "turbo run build",
    "build:apps": "turbo run build --filter='@egen/*-app'",
    "setup": "npm install && turbo run build",
    "preview": "turbo run preview",
    "type-check": "tsc --noEmit",
    "verify": "turbo run lint test type-check",
    "test": "turbo run test",
    "coverage": "turbo run test --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "rm -rf packages/tooling/webpack-config/node_modules/webpack packages/tooling/webpack-config/node_modules/webpack-cli packages/tooling/webpack-config/node_modules/webpack-dev-server || true",
    "start:all": "turbo run start",
    "start:mf": "turbo run start --filter='!@egen/esm-app-shell'",
    "mock:server": "tsx packages/tooling/mock-server/src/dev-server.ts",
    "dev:mock": "concurrently \"npm run mock:server\" \"npm run dev\"",
    "mock:install": "cd packages/tooling/mock-server && npm install"
  },
  "dependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-aria/utils": "^3.34.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@types/react-router-dom": "^5.3.3",
    "ajv": "^8.20.0",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.55.1",
    "@swc/core": "^1.11.29",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.5",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^6.0.1",
    "classnames": "^2.3.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.3",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-playwright": "^2.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-testing-library": "^7.1.1",
    "fake-indexeddb": "^4.0.2",
    "fork-ts-checker-webpack-plugin": "^7.2.13",
    "globals": "^17.5.0",
    "husky": "^8.0.3",
    "i18next-parser": "^9.3.0",
    "identity-obj-proxy": "^3.0.0",
    "lint-staged": "^15.2.9",
    "prettier": "^3.1.0",
    "swc-loader": "^0.2.6",
    "timezone-mock": "^1.2.2",
    "turbo": "^2.5.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "webpack": "^5.106.2",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix --max-warnings 0",
    "*.{css,scss,ts,tsx}": "prettier --write --list-different"
  },
  "packageManager": "npm@10.9.7",
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.5"
  }
}
