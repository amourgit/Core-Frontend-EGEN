# ============================================================
# EGEN CORE — Environment Variables
# Copy to .env.local for local development.
# ============================================================

# ── Dev Server ──────────────────────────────────────────────
EGEN_PORT=3001

# ── Micro-frontend URLs ──────────────────────────────────────
EGEN_IAM_URL=http://localhost:3000

# ── Backend API ──────────────────────────────────────────────
EGEN_API_URL=http://localhost:8080

# ── Keycloak / IAM ──────────────────────────────────────────
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=egen-frontend

# ── Shell Webpack (legacy MF modules) ───────────────────────
EGEN_PUBLIC_PATH=/egen/spa
EGEN_PROXY_TARGET=https://dev3.openmrs.org/
EGEN_PAGE_TITLE=EGEN Platform
EGEN_DEFAULT_LOCALE=fr
EGEN_OFFLINE=disable

# ── Import Maps ──────────────────────────────────────────────
# EGEN_IMPORTMAP={"@egen/esm-login-app":"http://localhost:8081/index.js"}
# EGEN_IMPORTMAP_URL=/egen/spa/importmap.json
# EGEN_ROUTES_URL=/egen/spa/routes.registry.json
# EGEN_CONFIG_URLS=/path/to/config.json
