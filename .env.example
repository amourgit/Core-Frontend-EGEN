# ============================================================
# IGEN CORE — Environment Variables
# Copy to .env.local for local development.
# ============================================================

# ── Dev Server ──────────────────────────────────────────────
IGEN_PORT=3001

# ── Micro-frontend URLs ──────────────────────────────────────
IGEN_IAM_URL=http://localhost:3000

# ── Backend API ──────────────────────────────────────────────
IGEN_API_URL=http://localhost:8080

# ── Keycloak / IAM ──────────────────────────────────────────
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=igen-frontend

# ── Shell Webpack (legacy MF modules) ───────────────────────
IGEN_PUBLIC_PATH=/eigen/spa
IGEN_PROXY_TARGET=https://dev.iam-central.ga/
IGEN_PAGE_TITLE=IGEN Platform
IGEN_DEFAULT_LOCALE=fr
IGEN_OFFLINE=disable

# ── Import Maps ──────────────────────────────────────────────
# IGEN_IMPORTMAP={"@igen/esm-login-app":"http://localhost:8081/index.js"}
# IGEN_IMPORTMAP_URL=/eigen/spa/importmap.json
# IGEN_ROUTES_URL=/eigen/spa/routes.registry.json
# IGEN_CONFIG_URLS=/path/to/config.json
