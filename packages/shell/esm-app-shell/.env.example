# ─── egen App Shell — Development environment ─────────────────────────────────
#
# BACKEND PROXY
# ─────────────
# Point webpack-dev-server proxy at the local mock server.
# Start the mock server with: npm run mock:server  (from repo root)
# Start everything together:  npm run dev:mock
#
EGEN_PROXY_TARGET=http://localhost:3333/

# ─── Optional overrides ───────────────────────────────────────────────────────
# EGEN_API_URL=/egen
# EGEN_PUBLIC_PATH=/egen/spa
# EGEN_PAGE_TITLE=egen (dev)
# EGEN_OFFLINE=disable
# MOCK_PORT=3333
