# ─── IGEN App Shell — Development environment ─────────────────────────────────
#
# BACKEND PROXY
# ─────────────
# Point webpack-dev-server proxy at the local mock server.
# Start the mock server with: npm run mock:server  (from repo root)
# Start everything together:  npm run dev:mock
#
IGEN_PROXY_TARGET=http://localhost:3333/

# ─── Optional overrides ───────────────────────────────────────────────────────
# IGEN_API_URL=/igen
# IGEN_PUBLIC_PATH=/igen/spa
# IGEN_PAGE_TITLE=IGEN (dev)
# IGEN_OFFLINE=disable
# MOCK_PORT=3333
