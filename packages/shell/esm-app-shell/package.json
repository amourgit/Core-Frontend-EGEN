{
  "name": "@egen/esm-app-shell",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "main": "dist/openmrs.js",
  "scripts": {
    "start": "yarn run watch",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "watch": "cross-env OMRS_CLEAN_BEFORE_BUILD=\"true\" NODE_ENV=\"development\" OMRS_OFFLINE=\"disable\" webpack serve --mode development",
    "watch:ref": "cross-env OMRS_ESM_IMPORTMAP_URL=\"https://dev3.iam-central.ga/eigen/spa/importmap.json\" OMRS_OFFLINE=\"disable\" OMRS_CLEAN_BEFORE_BUILD=\"true\" NODE_ENV=\"development\" webpack serve --mode development",
    "build:production": "cross-env OMRS_ESM_IMPORTMAP_URL=\"https://dev3.iam-central.ga/eigen/spa/importmap.json\" OMRS_OFFLINE=\"enable\" OMRS_CLEAN_BEFORE_BUILD=\"true\" NODE_ENV=\"production\" webpack --mode production",
    "build:development": "cross-env OMRS_OFFLINE=\"enable\" OMRS_CLEAN_BEFORE_BUILD=\"true\" NODE_ENV=\"development\" webpack --mode development",
    "build": "yarn run build:production && yarn run build:development",
    "analyze": "webpack --mode=production --env analyze=true",
    "lint": "eslint src --ext ts,tsx"
  },
  "keywords": [
    "eigen",
    "microfrontends"
  ],
  "browserslist": [
    "last 3 chrome versions",
    "last 3 firefox versions",
    "last 3 safari versions",
    "last 3 edge versions"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amourgit/Core-Frontend-IGEN.git"
  },
  "bugs": {
    "url": "https://github.com/amourgit/Core-Frontend-IGEN/issues"
  },
  "homepage": "https://github.com/amourgit/Core-Frontend-IGEN#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@carbon/react": "^1.92.1",
    "@internationalized/date": "^3.8.0",
    "@egen/esm-framework": "workspace:*",
    "@egen/esm-styleguide": "workspace:*",
    "dayjs": "^1.11.13",
    "dexie": "^3.0.3",
    "html-webpack-plugin": "^5.5.0",
    "i18next": "^25.5.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "import-map-overrides": "^3.0.0",
    "lodash-es": "^4.17.21",
    "mini-css-extract-plugin": "^2.9.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.3.0",
    "rxjs": "^6.5.3",
    "semver": "^7.7.3",
    "single-spa": "^6.0.3",
    "swc-loader": "^0.2.6",
    "swr": "2.2.5",
    "webpack": "^5.99.9",
    "webpack-pwa-manifest": "^4.3.0",
    "workbox-core": "^6.1.5",
    "workbox-routing": "^6.1.5",
    "workbox-strategies": "^6.1.5",
    "workbox-webpack-plugin": "^6.1.5",
    "workbox-window": "^6.1.5",
    "@igen/esm-auth": "workspace:*"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "vitest": "^4.0.18"
  }
}