{
  "name": "@egen/esm-devtools-app",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "description": "Dev tools for frontend devs using Egen",
  "browser": "dist/egen-esm-devtools-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "igen develop --importmap '{\"imports\":{}}'",
    "serve": "webpack serve --mode=development",
    "debug": "npm run serve",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch",
    "coverage": "cross-env TZ=UTC vitest run --coverage --passWithNoTests",
    "build": "webpack --mode=production",
    "build:development": "webpack --mode=development",
    "analyze": "webpack --mode=production --env analyze=true",
    "typescript": "tsc",
    "lint": "eslint src --ext ts,tsx",
    "extract-translations": "i18next 'src/**/*.tsx' --config='../../../tools/i18next-parser.config.js'",
    "start:connected": "igen develop --backend http://localhost:8080",
    "start:remote": "igen develop --backend https://dev.iam-central.ga"
  },
  "keywords": [
    "egen",
    "microfrontends"
  ],
  "browserslist": [
    "> 0.2%",
    "not dead",
    "not op_mini all"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amourgit/Core-Frontend-EGEN.git"
  },
  "bugs": {
    "url": "https://github.com/amourgit/Core-Frontend-EGEN/issues"
  },
  "homepage": "https://github.com/amourgit/Core-Frontend-EGEN#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@carbon/react": "1.x",
    "@egen/esm-framework": "9.x",
    "react": "^18.0 || ^19.0",
    "react-dom": "^18.0 || ^19.0",
    "react-i18next": "16.x",
    "rxjs": "6.x"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^7.0.3",
    "happy-dom": "^20.6.0",
    "egen": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@carbon/react": "^1.92.1",
    "fuzzy": "^0.1.3"
  }
}
