{
  "extends": "./tsconfig.json",
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.*",
    "**/*.spec.*"
  ],
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@egen/esm-shared-types": [
        "../esm-shared-types/dist/index"
      ],
      "@egen/esm-shared-utils": [
        "../esm-shared-utils/dist/index"
      ],
      "@egen/esm-shared-hooks": [
        "../esm-shared-hooks/dist/index"
      ]
    },
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  }
}