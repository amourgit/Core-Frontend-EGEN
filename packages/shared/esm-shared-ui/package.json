{
  "name": "@egen/esm-shared-ui",
  "version": "9.0.2",
  "description": "Composants UI partag\u00e9s entre tous les micro-frontends egen",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@egen/esm-shared-types": "*",
    "@egen/esm-shared-utils": "*",
    "@egen/esm-shared-hooks": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0"
  }
}