{
  "name": "@igen/esm-shared-ui",
  "version": "9.0.2",
  "description": "Composants UI partagés entre tous les micro-frontends IGEN",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@igen/esm-shared-types": "*",
    "@igen/esm-shared-utils": "*",
    "@igen/esm-shared-hooks": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0",
    "rimraf": "^5.0.0"
  }
}
