{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "paths": {
      "@igen/esm-shared-types": ["../esm-shared-types/src/index.ts"],
      "@igen/esm-shared-utils": ["../esm-shared-utils/src/index.ts"],
      "@igen/esm-shared-hooks": ["../esm-shared-hooks/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/*.test.*"]
}
