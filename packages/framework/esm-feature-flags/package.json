{
  "name": "@egen/esm-feature-flags",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "description": "A feature flag system for the Egen Single-Spa framework.",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./src/public": {
      "types": "./src/public.ts",
      "default": "./dist/public.js"
    }
  },
  "source": true,
  "scripts": {
    "build": "rimraf dist && concurrently \"swc --strip-leading-paths src -d dist\" \"tsc --project tsconfig.build.json\"",
    "build:development": "rimraf dist && concurrently \"swc --strip-leading-paths src -d dist\" \"tsc --project tsconfig.build.json\"",
    "typescript": "tsc --project tsconfig.build.json",
    "lint": "eslint src --ext ts,tsx"
  },
  "keywords": [
    "egen",
    "microfrontends"
  ],
  "directories": {
    "lib": "dist",
    "src": "src"
  },
  "browserslist": [
    "> 0.2%", "not dead", "not op_mini all"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amourgit/Core-Frontend-EGEN.git"
  },
  "bugs": {
    "url": "https://github.com/amourgit/Core-Frontend-EGEN/issues"
  },
  "homepage": "https://github.com/amourgit/Core-Frontend-EGEN#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@egen/esm-globals": "9.x",
    "@egen/esm-state": "9.x",
    "single-spa": "6.x"
  },
  "devDependencies": {
    "@egen/esm-globals": "*",
    "@egen/esm-state": "*",
    "@swc/cli": "^0.7.7",
    "@swc/core": "^1.11.29",
    "concurrently": "^9.1.2",
    "rimraf": "^6.0.1",
    "single-spa": "^6.0.3"
  }
}
