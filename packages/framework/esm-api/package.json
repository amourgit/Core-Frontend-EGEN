{
  "name": "@egen/esm-api",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "description": "The javascript module for interacting with the EGEN API",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./src/public": {
      "types": "./src/public.ts",
      "default": "./dist/public.js"
    },
    "./mock": {
      "import": "./mock.ts",
      "require": "./mock-jest.ts"
    },
    "./sdk": {
      "types": "./src/sdk.ts",
      "default": "./src/sdk.ts"
    }
  },
  "source": true,
  "scripts": {
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch --passWithNoTests",
    "coverage": "cross-env TZ=UTC vitest run --coverage --passWithNoTests",
    "build": "rimraf dist && concurrently \"swc --strip-leading-paths src -d dist\" \"tsc --project tsconfig.build.json\"",
    "build:development": "rimraf dist && concurrently \"swc --strip-leading-paths src -d dist\" \"tsc --project tsconfig.build.json\"",
    "typescript": "tsc --project tsconfig.build.json",
    "lint": "eslint src --ext ts,tsx"
  },
  "keywords": [
    "egen",
    "microfrontends"
  ],
  "directories": {
    "lib": "dist",
    "src": "src"
  },
  "browserslist": [
    "last 3 chrome versions",
    "last 3 firefox versions",
    "last 3 safari versions",
    "last 3 edge versions"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amourgit/Core-Frontend-EGEN.git"
  },
  "bugs": {
    "url": "https://github.com/amourgit/Core-Frontend-EGEN/issues"
  },
  "homepage": "https://github.com/amourgit/Core-Frontend-EGEN#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "lodash-es": "^4.17.21"
  },
  "peerDependencies": {
    "@egen/esm-config": "9.x",
    "@egen/esm-error-handling": "9.x",
    "@egen/esm-globals": "9.x",
    "@egen/esm-navigation": "9.x"
  },
  "devDependencies": {
    "@egen/esm-config": "*",
    "@egen/esm-error-handling": "*",
    "@egen/esm-globals": "*",
    "@egen/esm-navigation": "*",
    "@swc/cli": "^0.7.7",
    "@swc/core": "^1.11.29",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "happy-dom": "^20.6.0",
    "rimraf": "^6.0.1",
    "rxjs": "^6.5.3",
    "vitest": "^4.0.18"
  }
}