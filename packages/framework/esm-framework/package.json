{
  "name": "@egen/esm-framework",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "type": "module",
  "module": "dist/egen-esm-framework.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/internal": {
      "types": "./src/internal.ts",
      "default": "./src/internal.ts"
    },
    "./package.json": {
      "default": "./package.json"
    },
    "./mock": {
      "import": "./mock.tsx",
      "require": "./mock-jest.tsx"
    },
    "./mock.tsx": {
      "import": "./mock.tsx",
      "require": "./mock-jest.tsx"
    }
  },
  "source": true,
  "scripts": {
    "document": "../../../document.sh esm-framework",
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch",
    "coverage": "cross-env TZ=UTC vitest run --coverage --passWithNoTests",
    "build": "concurrently \"rspack --mode=production\" \"tsc --project tsconfig.build.json\"",
    "build:development": "concurrently \"rspack --mode=development\" \"tsc --project tsconfig.build.json\"",
    "analyze": "rspack --mode=production --env analyze=true",
    "typescript": "tsc --project tsconfig.build.json",
    "lint": "eslint src --ext ts,tsx"
  },
  "keywords": [
    "egen",
    "framework",
    "frontend",
    "ui",
    "microfrontends"
  ],
  "browserslist": [
    "> 0.2%", "not dead", "not op_mini all"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amourgit/Core-Frontend-EGEN.git"
  },
  "bugs": {
    "url": "https://github.com/amourgit/Core-Frontend-EGEN/issues"
  },
  "homepage": "https://github.com/amourgit/Core-Frontend-EGEN#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@egen/esm-api": "*",
    "@egen/esm-config": "*",
    "@egen/esm-context": "*",
    "@egen/esm-dynamic-loading": "*",
    "@egen/esm-error-handling": "*",
    "@egen/esm-expression-evaluator": "*",
    "@egen/esm-extensions": "*",
    "@egen/esm-feature-flags": "*",
    "@egen/esm-globals": "*",
    "@egen/esm-navigation": "*",
    "@egen/esm-offline": "*",
    "@egen/esm-react-utils": "*",
    "@egen/esm-routes": "*",
    "@egen/esm-state": "*",
    "@egen/esm-styleguide": "*",
    "@egen/esm-translations": "*",
    "@egen/esm-utils": "*",
    "@egen/esm-egen-api": "*"
  },
  "peerDependencies": {
    "dayjs": "1.x",
    "i18next": "25.x",
    "react": "^18.0 || ^19.0",
    "react-dom": "^18.0 || ^19.0",
    "react-i18next": "16.x",
    "rxjs": "6.x",
    "single-spa": "6.x",
    "swr": "2.x"
  },
  "devDependencies": {
    "@egen/typedoc-plugin-file-categories": "*",
    "@rspack/cli": "1.3.15",
    "@rspack/core": "1.3.15",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "happy-dom": "^20.6.0",
    "sass-embedded": "1.89.0",
    "svgo-loader": "4.0.0",
    "typedoc": "^0.28.5",
    "typedoc-plugin-markdown": "^4.6.3",
    "typedoc-plugin-no-inherit": "^1.6.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
