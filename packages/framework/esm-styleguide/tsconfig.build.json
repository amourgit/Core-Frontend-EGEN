{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "extends": "./tsconfig.json",
  "exclude": [
    "**/*.test.*",
    "**/setup-tests.ts",
    "**/__mocks__/*"
  ]
}