{
  "name": "@egen/esm-utils",
  "version": "9.0.2",
  "license": "MPL-2.0",
  "description": "Helper utilities for OpenMRS",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "source": true,
  "sideEffects": false,
  "scripts": {
    "test": "cross-env TZ=UTC vitest run --passWithNoTests",
    "test:watch": "cross-env TZ=UTC vitest watch --passWithNoTests",
    "coverage": "cross-env TZ=UTC vitest run --coverage --passWithNoTests",
    "build": "rimraf dist && concurrently \"swc --strip-leading-paths src -d dist\" \"tsc --project tsconfig.build.json\"",
    "build:development": "rimraf dist && concurrently \"swc --strip-leading-paths src -d dist\" \"tsc --project tsconfig.build.json\"",
    "typescript": "tsc --project tsconfig.build.json",
    "lint": "eslint src --ext ts,tsx"
  },
  "keywords": [
    "eigen",
    "microfrontends"
  ],
  "directories": {
    "lib": "dist",
    "src": "src"
  },
  "browserslist": [
    "extends browserslist-config-igen"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amourgit/Core-Frontend-IGEN.git"
  },
  "bugs": {
    "url": "https://github.com/amourgit/Core-Frontend-IGEN/issues"
  },
  "homepage": "https://github.com/amourgit/Core-Frontend-IGEN#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@formatjs/intl-durationformat": "^0.7.3",
    "@internationalized/date": "^3.8.0",
    "any-date-parser": "^2.0.3",
    "lodash-es": "^4.17.21",
    "semver": "^7.7.3"
  },
  "peerDependencies": {
    "@egen/esm-globals": "9.x",
    "dayjs": "1.x",
    "i18next": "25.x",
    "rxjs": "6.x"
  },
  "devDependencies": {
    "@egen/esm-globals": "workspace:*",
    "@swc/cli": "^0.7.7",
    "@swc/core": "^1.11.29",
    "@types/lodash-es": "^4.17.12",
    "@types/semver": "^7.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.13",
    "happy-dom": "^20.6.0",
    "rimraf": "^6.0.1",
    "rxjs": "^6.5.3",
    "vitest": "^4.0.18"
  }
}
