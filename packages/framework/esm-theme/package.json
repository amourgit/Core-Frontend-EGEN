{
  "name": "@eigen/esm-theme",
  "version": "1.0.0",
  "license": "MPL-2.0",
  "description": "EIGEN Theme System — token-based theming, dark mode, glass morphism",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./globals.css": {
      "default": "./src/globals.css"
    }
  },
  "source": true,
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint src"
  },
  "keywords": ["eigen", "theme", "dark-mode", "glass-morphism", "css-variables"],
  "peerDependencies": {
    "react": "18.x",
    "react-dom": "18.x"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "react": "^18.3.1"
  }
}
