{
  "name": "@egen/esm-theme",
  "version": "1.0.0",
  "license": "MPL-2.0",
  "description": "EGEN Theme System \u2014 compatibility shim re-exporting from @egen/esm-styleguide",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "source": true,
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "lint": "eslint src"
  },
  "keywords": [
    "egen",
    "theme",
    "dark-mode",
    "glass-morphism",
    "css-variables"
  ],
  "peerDependencies": {
    "react": "18.x",
    "react-dom": "18.x",
    "@egen/esm-styleguide": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "react": "^18.3.1"
  }
}